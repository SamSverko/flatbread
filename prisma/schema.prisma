// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
// Model field scalar types: https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#model-field-scalar-types
// Relations: https://www.prisma.io/docs/concepts/components/prisma-schema/relations

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("PRISMA_DATABASE_URL")
}

// RECIPE =====================================================================
model Recipe {
    id                  String                     @id @default(uuid())
    createdAt           DateTime                   @default(now())
    title               String
    sourceName          String
    sourceURL           String?
    prepTimeMin         Int
    cookTimeMin         Int
    servingAmount       Int
    servingUnit         RecipeServingUnit          @relation(fields: [servingUnitId], references: [id])
    servingUnitId       Int
    courseTypes         RecipeCourseType[]
    cuisines            RecipeCuisine[]
    dietaryRestrictions RecipeDietaryRestriction[]
    dishTypes           RecipeDishType[]
    ingredients         RecipeIngredient[]
    steps               RecipeStep[]
    notes               RecipeNote[]

    @@unique(fields: [title, sourceName], name: "recipe_identifier")
}

model RecipeServingUnit {
    id         Int      @id @unique @default(autoincrement())
    createdAt  DateTime @default(now())
    name       String   @unique
    namePlural String   @unique
    recipes    Recipe[]
}

model RecipeCourseType {
    id        Int      @id @unique @default(autoincrement())
    createdAt DateTime @default(now())
    name      String   @unique
    recipes   Recipe[]
}

model RecipeCuisine {
    id        Int      @id @unique @default(autoincrement())
    createdAt DateTime @default(now())
    name      String   @unique
    recipes   Recipe[]
}

model RecipeDietaryRestriction {
    id        Int      @id @unique @default(autoincrement())
    createdAt DateTime @default(now())
    name      String   @unique
    recipes   Recipe[]
}

model RecipeDishType {
    id        Int      @id @unique @default(autoincrement())
    createdAt DateTime @default(now())
    name      String   @unique
    recipes   Recipe[]
}

// RECIPE / INGREDIENT ========================================================
model RecipeIngredient {
    id                 Int                              @id @unique @default(autoincrement())
    createdAt          DateTime                         @default(now())
    recipe             Recipe                           @relation(fields: [recipeId], references: [id])
    recipeId           String
    order              Int
    section            String?
    quantityWhole      Int
    quantityFraction   RecipeIngredientQuantityFraction @relation(fields: [quantityFractionId], references: [id])
    quantityFractionId Int
    unit               RecipeIngredientUnit             @relation(fields: [unitId], references: [id])
    unitId             Int
    name               RecipeIngredientName             @relation("name", fields: [nameId], references: [id])
    nameId             Int
    alteration         String?
    isOptional         Boolean                          @default(false)
    substitutions      RecipeIngredientName[]           @relation("substitutions")

    @@unique(fields: [recipeId, order], name: "recipe_ingredient_identifier")
}

model RecipeIngredientQuantityFraction {
    id                Int                @id @unique @default(autoincrement())
    createdAt         DateTime           @default(now())
    name              String             @unique
    value             Decimal            @unique
    recipeIngredients RecipeIngredient[]
}

model RecipeIngredientUnit {
    id                Int                @id @unique @default(autoincrement())
    createdAt         DateTime           @default(now())
    name              String             @unique
    nameAbbr          String             @unique
    namePlural        String             @unique
    recipeIngredients RecipeIngredient[]
}

model RecipeIngredientName {
    id                            Int                @id @unique @default(autoincrement())
    createdAt                     DateTime           @default(now())
    name                          String             @unique
    namePlural                    String             @unique
    RecipeIngredientName          RecipeIngredient[] @relation("name")
    RecipeIngredientSubstitutions RecipeIngredient[] @relation("substitutions")
}

// RECIPE / STEP ==============================================================
model RecipeStep {
    id        Int      @id @unique @default(autoincrement())
    createdAt DateTime @default(now())
    recipe    Recipe   @relation(fields: [recipeId], references: [id])
    recipeId  String
    order     Int
    section   String?
    details   String

    @@unique(fields: [recipeId, order], name: "recipe_step_identifier")
}

// RECIPE / NOTE ==============================================================
model RecipeNote {
    id        Int      @id @unique @default(autoincrement())
    createdAt DateTime @default(now())
    recipe    Recipe   @relation(fields: [recipeId], references: [id])
    recipeId  String
    order     Int
    section   String?
    details   String

    @@unique(fields: [recipeId, order], name: "recipe_note_identifier")
}
