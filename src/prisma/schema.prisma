// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
// Model field scalar types: https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#model-field-scalar-types
// Relations: https://www.prisma.io/docs/concepts/components/prisma-schema/relations

generator client {
    provider        = "prisma-client-js"
    previewFeatures = ["fullTextSearch"]
}

datasource db {
    provider = "postgresql"
    url      = env("PRISMA_DATABASE_URL")
}

// RECIPE =====================================================================
model Recipe {
    id                  String               @id @default(uuid())
    createdAt           DateTime             @default(now())
    title               String
    slug                String               @unique
    sourceName          String
    sourceURL           String?
    prepTimeMins        Int
    cookTimeMins        Int
    servingAmount       Int
    servingUnit         ServingUnit          @relation(fields: [servingUnitId], references: [id])
    servingUnitId       Int
    courseTypes         CourseType[]
    cuisines            Cuisine[]
    dietaryRestrictions DietaryRestriction[]
    dishTypes           DishType[]
    ingredients         RecipeIngredient[]
    steps               RecipeStep[]
    notes               RecipeNote[]

    @@unique(fields: [title, sourceName], name: "recipe_identifier")
}

model RecipeIngredient {
    id                    Int               @id @unique @default(autoincrement())
    createdAt             DateTime          @default(now())
    recipe                Recipe            @relation(fields: [recipeId], references: [id])
    recipeId              String
    order                 Int
    section               String?
    quantityWhole         Int?
    quantityFraction      QuantityFraction? @relation("recipe_ingredient_quantity_fraction", fields: [quantityFractionId], references: [id])
    quantityFractionId    Int?
    quantityMinWhole      Int?
    quantityMinFraction   QuantityFraction? @relation("recipe_ingredient_quantity_fraction_min", fields: [quantityMinFractionId], references: [id])
    quantityMinFractionId Int?
    quantityMaxWhole      Int?
    quantityMaxFraction   QuantityFraction? @relation("recipe_ingredient_quantity_fraction_max", fields: [quantityMaxFractionId], references: [id])
    quantityMaxFractionId Int?
    unit                  IngredientUnit?   @relation(fields: [unitId], references: [id])
    unitId                Int?
    name                  Ingredient        @relation("recipe_ingredient_name", fields: [nameId], references: [id])
    nameId                Int
    alteration            String?
    isOptional            Boolean           @default(false)
    substitutions         Ingredient[]      @relation("recipe_ingredient_substitutions")

    @@unique(fields: [recipeId, order], name: "recipe_ingredient_identifier")
}

model RecipeStep {
    id        Int      @id @unique @default(autoincrement())
    createdAt DateTime @default(now())
    recipe    Recipe   @relation(fields: [recipeId], references: [id])
    recipeId  String
    order     Int
    section   String?
    details   String

    @@unique(fields: [recipeId, order], name: "recipe_step_identifier")
}

model RecipeNote {
    id        Int      @id @unique @default(autoincrement())
    createdAt DateTime @default(now())
    recipe    Recipe   @relation(fields: [recipeId], references: [id])
    recipeId  String
    order     Int
    section   String?
    details   String

    @@unique(fields: [recipeId, order], name: "recipe_note_identifier")
}

// GENERAL ====================================================================
model Ingredient {
    id                            Int                @id @unique @default(autoincrement())
    createdAt                     DateTime           @default(now())
    name                          String             @unique
    namePlural                    String             @unique
    Ingredient                    RecipeIngredient[] @relation("recipe_ingredient_name")
    RecipeIngredientSubstitutions RecipeIngredient[] @relation("recipe_ingredient_substitutions")
}

model IngredientUnit {
    id                Int                @id @unique @default(autoincrement())
    createdAt         DateTime           @default(now())
    name              String             @unique
    nameAbbr          String             @unique
    namePlural        String             @unique
    recipeIngredients RecipeIngredient[]
}

model QuantityFraction {
    id                           Int                @id @unique @default(autoincrement())
    createdAt                    DateTime           @default(now())
    name                         String             @unique
    value                        Decimal            @unique
    recipeIngredientsQuantity    RecipeIngredient[] @relation("recipe_ingredient_quantity_fraction")
    recipeIngredientsQuantityMin RecipeIngredient[] @relation("recipe_ingredient_quantity_fraction_min")
    recipeIngredientsQuantityMax RecipeIngredient[] @relation("recipe_ingredient_quantity_fraction_max")
}

model ServingUnit {
    id         Int      @id @unique @default(autoincrement())
    createdAt  DateTime @default(now())
    name       String   @unique
    namePlural String   @unique
    recipes    Recipe[]
}

// GENERAL / CATEGORIES =======================================================
model CourseType {
    id        Int      @id @unique @default(autoincrement())
    createdAt DateTime @default(now())
    name      String   @unique
    recipes   Recipe[]
}

model Cuisine {
    id        Int      @id @unique @default(autoincrement())
    createdAt DateTime @default(now())
    name      String   @unique
    recipes   Recipe[]
}

model DietaryRestriction {
    id        Int      @id @unique @default(autoincrement())
    createdAt DateTime @default(now())
    name      String   @unique
    recipes   Recipe[]
}

model DishType {
    id        Int      @id @unique @default(autoincrement())
    createdAt DateTime @default(now())
    name      String   @unique
    recipes   Recipe[]
}
