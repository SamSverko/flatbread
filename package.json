{
    "name": "flatbread",
    "version": "2022.06.07",
    "description": "\"People who love to eat are always the best people. - Julia Child\" - Flatbread",
    "keywords": [
        "food",
        "hobby-project",
        "open-source",
        "recipes"
    ],
    "homepage": "https://github.com/SamSverko/flatbread",
    "bugs": {
        "url": "https://github.com/SamSverko/flatbread/issues",
        "email": "sam.sverko@gmail.com"
    },
    "license": "MIT",
    "author": {
        "name": "Sam Sverko",
        "email": "sam.sverko@gmail.com",
        "url": "https://github.com/SamSverko"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/SamSverko/flatbread.git"
    },
    "prisma": {
        "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} src/prisma/seed.ts",
        "schema": "src/prisma/schema.prisma"
    },
    "scripts": {
        "build": "npm run lint && next build",
        "db-generate": "dotenv -e .env.local -- prisma generate",
        "db-migrate-dev": "dotenv -e .env.local -- prisma migrate dev",
        "db-push": "dotenv -e .env.local -- prisma db push",
        "db-reset": "dotenv -e .env.local -- prisma db push --force-reset",
        "db-reset-seed": "npm run db-reset; npm run db-seed",
        "db-seed": "dotenv -e .env.local -- prisma db seed",
        "db-studio": "dotenv -e .env.local -- prisma db studio",
        "dev": "next dev",
        "lint": "next lint && npx stylelint \"**/*.{css,scss}\"",
        "start": "next start"
    },
    "dependencies": {
        "@prisma/client": "^4.11.0",
        "next": "13.2.3",
        "next-auth": "^4.20.1",
        "react": "18.2.0",
        "react-dom": "18.2.0",
        "uuid": "^9.0.0"
    },
    "devDependencies": {
        "@types/node": "18.14.6",
        "@types/react": "18.0.28",
        "@types/react-dom": "18.0.11",
        "@types/uuid": "^9.0.1",
        "@typescript-eslint/eslint-plugin": "^5.54.0",
        "@typescript-eslint/parser": "^5.54.0",
        "babel-plugin-inline-react-svg": "^2.0.2",
        "dotenv-cli": "^7.0.0",
        "eslint": "8.35.0",
        "eslint-config-next": "13.2.3",
        "eslint-config-standard": "^17.0.0",
        "eslint-plugin-import": "^2.27.5",
        "eslint-plugin-node": "^11.1.0",
        "eslint-plugin-promise": "^6.1.1",
        "eslint-plugin-react": "^7.32.2",
        "prisma": "^4.11.0",
        "sass": "^1.58.3",
        "stylelint": "^15.2.0",
        "stylelint-config-standard-scss": "^7.0.1",
        "stylelint-order": "^6.0.2",
        "ts-node": "^10.9.1",
        "typescript": "4.9.5"
    }
}
