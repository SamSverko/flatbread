{
    "name": "flatbread",
    "version": "2022.06.07",
    "description": "\"People who love to eat are always the best people. - Julia Child\" - Flatbread",
    "keywords": [
        "food",
        "hobby-project",
        "open-source",
        "recipes"
    ],
    "homepage": "https://github.com/SamSverko/flatbread",
    "bugs": {
        "url": "https://github.com/SamSverko/flatbread/issues",
        "email": "sam.sverko@gmail.com"
    },
    "license": "MIT",
    "author": {
        "name": "Sam Sverko",
        "email": "sam.sverko@gmail.com",
        "url": "https://github.com/SamSverko"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/SamSverko/flatbread.git"
    },
    "type": "module",
    "prisma": {
        "seed": "ts-node --esm prisma/seed.ts"
    },
    "scripts": {
        "dev": "next dev",
        "db-seed": "dotenv -e .env.local -- prisma db seed",
        "db-push": "dotenv -e .env.local -- prisma db push",
        "db-reset": "dotenv -e .env.local -- prisma db push --force-reset",
        "db-studio": "dotenv -e .env.local -- prisma db studio",
        "build": "npm run lint && next build",
        "start": "next start",
        "lint": "next lint && npx stylelint \"**/*.{css,scss}\""
    },
    "dependencies": {
        "@prisma/client": "^4.4.0",
        "contentful": "^9.1.5",
        "next": "12.0.7",
        "next-pwa": "^5.5.0",
        "react": "17.0.2",
        "react-dom": "17.0.2",
        "uuid": "^9.0.0"
    },
    "devDependencies": {
        "@types/node": "^18.8.3",
        "@types/react": "17.0.37",
        "@types/uuid": "^8.3.4",
        "@typescript-eslint/eslint-plugin": "^5.7.0",
        "@typescript-eslint/parser": "^5.7.0",
        "babel-plugin-inline-react-svg": "^2.0.1",
        "contentful-ts-type-generator": "github:arimkevi/contentful-ts-type-generator",
        "dotenv-cli": "^6.0.0",
        "eslint": "^7.32.0",
        "eslint-config-next": "12.0.7",
        "eslint-config-standard": "^16.0.3",
        "eslint-plugin-import": "^2.25.3",
        "eslint-plugin-node": "^11.1.0",
        "eslint-plugin-promise": "^5.2.0",
        "eslint-plugin-react": "^7.27.1",
        "prisma": "^4.4.0",
        "sass": "^1.49.9",
        "stylelint": "^14.6.0",
        "stylelint-config-standard-scss": "^3.0.0",
        "stylelint-order": "^5.0.0",
        "ts-node": "^10.9.1",
        "typescript": "^4.8.4"
    }
}
